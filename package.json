{
  "name": "@bleizlabs/ui",
  "version": "0.26.0",
  "description": "Zero-dependency, fully-styled React component library with seed-based design tokens. 100+ focused components with 100% JSDoc coverage, WAI-ARIA compliant, SCSS Modules, React 19.2 + Next.js 16.2. Ships with `bleizlabs-ui` CLI for project scaffold + agent-friendly docs (`AGENTS.md` + `docs/AGENT-USAGE.md`).",
  "license": "MIT",
  "author": "BleizLabs <hello@bleizlabs.eu>",
  "homepage": "https://github.com/BleizLabs/bleizlabs-ui#readme",
  "bugs": "https://github.com/BleizLabs/bleizlabs-ui/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BleizLabs/bleizlabs-ui.git"
  },
  "keywords": [
    "react",
    "nextjs",
    "component-library",
    "ui",
    "scss",
    "design-system",
    "zero-dependency",
    "wai-aria",
    "a11y",
    "agent-docs",
    "claude-code"
  ],
  "type": "module",
  "main": "./components/index.ts",
  "module": "./components/index.ts",
  "types": "./components/index.ts",
  "exports": {
    ".": {
      "types": "./components/index.ts",
      "default": "./components/index.ts"
    },
    "./styles": "./styles/index.scss",
    "./styles/project-settings": "./styles/_project-settings.scss",
    "./styles/*": "./styles/*",
    "./components/*": "./components/*",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "*.scss",
    "*.css"
  ],
  "files": [
    "components",
    "!components/**/tests",
    "styles",
    "cli-dist",
    "docs/AGENT-USAGE.md",
    "AGENTS.md",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "bleizlabs-ui": "cli-dist/bin.js"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint \"{app,components,styles,playground}/**/*.{css,scss}\"",
    "lint:css:fix": "stylelint \"{app,components,styles,playground}/**/*.{css,scss}\" --fix",
    "format": "prettier --write \"{app,cli,components,docs,playground,scripts,styles,tests}/**/*.{css,scss,js,jsx,mjs,ts,tsx,json,md}\" \"*.{js,mjs,json,md}\"",
    "format:check": "prettier --check \"{app,cli,components,docs,playground,scripts,styles,tests}/**/*.{css,scss,js,jsx,mjs,ts,tsx,json,md}\" \"*.{js,mjs,json,md}\"",
    "typecheck": "tsc --noEmit",
    "check:barrel": "node scripts/check-barrel.mjs",
    "build:manifest": "node scripts/build-component-manifest.mjs",
    "check:manifest": "node scripts/check-manifest.mjs",
    "audit:jsdoc": "node scripts/audit-jsdoc.mjs",
    "audit:demos": "node scripts/audit-demo-coverage.mjs",
    "build:cli": "tsup --config cli/tsup.config.ts",
    "dev:cli": "tsup --config cli/tsup.config.ts --watch",
    "test:cli": "vitest run --config cli/vitest.config.ts",
    "test:cli:watch": "vitest --config cli/vitest.config.ts",
    "tokens:build": "node playground/build.mjs",
    "tokens:verify": "node playground/build.mjs",
    "test": "playwright test",
    "test:smoke": "playwright test tests/smoke.spec.ts tests/baseline-reset.spec.ts",
    "test:e2e": "playwright test components/",
    "test:headed": "playwright test --headed",
    "verify": "npm run lint && npm run lint:css && npm run typecheck",
    "prepack": "npm run build:cli",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run check:barrel && npm run build:manifest && npm run check:manifest && node scripts/build-agent-inventory.mjs && node scripts/check-agents-doc.mjs && npm run build:cli && npm run test:cli && npm run build && node scripts/inject-doc-version.mjs",
    "postpublish": "node scripts/inject-doc-version.mjs --revert"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "sass": ">=1.80.0"
  },
  "peerDependenciesMeta": {
    "sass": {
      "optional": true
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@axe-core/react": "^4.11.2",
    "@inquirer/prompts": "^7.0.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "commander": "^12.1.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "next": "^16.2.6",
    "picocolors": "^1.1.1",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sass": "^1.83.0",
    "stylelint": "^17.11.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
